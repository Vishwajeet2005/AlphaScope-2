# Copy this to .env.local for local dev with netlify dev
# Add these in Netlify dashboard → Site settings → Environment variables

# REQUIRED: Anthropic API key for AI briefs (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED: Secret for JWT signing - use a long random string
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production

# Optional: seed users data (JSON string) for Netlify's ephemeral filesystem
# USERS_SEED={"users":[]}
